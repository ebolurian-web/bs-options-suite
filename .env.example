# Polygon.io API key — free tier works for this app.
# Sign up: https://polygon.io/signup  (no credit card required for Basic/free plan)
# Dashboard → API Keys: copy and paste here, save as .env.local (gitignored).
POLYGON_API_KEY=

# Marketdata.app API token (optional fallback).
# Sign up: https://www.marketdata.app/pricing  (free tier: 100 req/day)
# Leave empty to skip fallback and use static JSON instead.
MARKETDATA_API_TOKEN=

# Feature flags
NEXT_PUBLIC_ENABLE_LIVE_DATA=true
